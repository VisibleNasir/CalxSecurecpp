<UI version="4.0">
	<class>HomeClass</class>
	<widget class="QWidget" name="HomeClass">
		<property name="styleSheet">
			<string notr="true">
				QWidget {
				background-color: #050505;
				color: white;
				font-family: Inter, Segoe UI, system-ui;
				}

				QLabel#heroTitle {
				font-size: 72px;
				font-weight: 900;
				line-height: 1.1;
				letter-spacing: -2px;
				}

				QLabel#heroSubtitle {
				font-size: 22px;
				color: #a1a1aa;
				font-weight: 400;
				line-height: 1.4;
				}

				/* Navbar */
				QFrame#navbar {
				background-color: rgba(5, 5, 5, 0.95);
				border-bottom: 1px solid #27272a;
				}

				QPushButton#navBtn {
				background: transparent;
				border: none;
				padding: 8px 20px;
				font-size: 15px;
				font-weight: 500;
				color: #e5e5e5;
				}

				QPushButton#navBtn:hover {
				color: white;
				background-color: #1f1f22;
				border-radius: 8px;
				}

				QPushButton#logo {
				font-size: 22px;
				font-weight: 800;
				color: #3b82f6;
				background: transparent;
				border: none;
				}

				/* Primary Button */
				QPushButton#primaryBtn {
				background-color: #ffffff;
				color: #000000;
				border-radius: 12px;
				padding: 16px 36px;
				font-size: 17px;
				font-weight: 700;
				}
				QPushButton:pressed {
				background-color: #cccccc;
				}

				QPushButton#primaryBtn:pressed {
				background-color: #d1d5db;
				}

				/* Cards */
				QFrame#card {
				background-color: #0a0a0a;
				border: 1px solid #27272a;
				border-radius: 20px;
				padding: 32px;
				}

				QFrame#card:hover {
				border: 1px solid #60a5fa;
				background-color: #111113;
				transform: translateY(-4px);
				}

				/* Section Titles */
				QLabel#sectionTitle {
				font-size: 42px;
				font-weight: 700;
				letter-spacing: -1px;
				}
			</string>
		</property>

				/* Muted Text */
				QLabel#mutedText {
				color: #a1a1aa;
				font-size: 16px;
				line-height: 1.6;
				}

				/* Footer */
				QFrame#footer {
				background-color: #0a0a0a;
				border-top: 1px solid #27272a;
				padding: 40px 0;
				}
			</string>
		</property>

		<layout class="QVBoxLayout">
