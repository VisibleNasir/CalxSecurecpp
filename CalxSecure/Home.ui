<UI version="4.0">
	<class>HomeClass</class>
	<widget class="QWidget" name="HomeClass">

		<property name="styleSheet">
			<string notr="true">

				QWidget {
				background-color: #050505;
				color: white;
				font-family: Inter, Segoe UI;
				}

				QLabel#heroTitle {
				font-size: 56px;
				font-weight: 900;
				}

				QLabel#heroSubtitle {
				font-size: 18px;
				color: #a1a1aa;
				}

				QPushButton#primaryBtn {
				background-color: #ffffff;
				color: black;
				border-radius: 10px;
				padding: 14px 28px;
				font-weight: bold;
				}

				QPushButton#primaryBtn:hover {
				background-color: #e5e5e5;
				}

				QFrame#card {
				background-color: #0a0a0a;
				border: 1px solid #27272a;
				border-radius: 16px;
				padding: 28px;
				}

				QFrame#card:hover {
				border: 1px solid #ffffff;
				background-color: #111113;
				}

				QLabel#sectionTitle {
				font-size: 32px;
				font-weight: bold;
				}

				QLabel#mutedText {
				color: #a1a1aa;
				font-size: 15px;
				}

				QFrame#footer {
				border-top: 1px solid #27272a;
				padding-top: 20px;
				}

			</string>
		</property>

		<layout class="QVBoxLayout">
			<property name="margin">
				<number>0</number>
			</property>

			<item>
				<widget class="QScrollArea" name="scrollArea">
					<property name="widgetResizable">
						<bool>true</bool>
					</property>

					<widget class="QWidget" name="scrollContent">
						<layout class="QVBoxLayout">

							<property name="spacing">
								<number>80</number>
							</property>
							<property name="leftMargin">
								<number>120</number>
							</property>
							<property name="rightMargin">
								<number>120</number>
							</property>
							<property name="topMargin">
								<number>80</number>
							</property>
							<property name="bottomMargin">
								<number>80</number>
							</property>

							<!-- HERO -->
							<item alignment="Qt::AlignHCenter">
								<widget class="QLabel" name="heroTitle">
									<property name="text">
										<string>Secure Payments. Simplified.</string>
									</property>
								</widget>
							</item>

							<item alignment="Qt::AlignHCenter">
								<widget class="QLabel" name="heroSubtitle">
									<property name="text">
										<string>Send, receive, and manage money with next-gen encryption and speed.</string>
									</property>
								</widget>
							</item>

							<item alignment="Qt::AlignHCenter">
								<widget class="QPushButton" name="primaryBtn">
									<property name="text">
										<string>Get Started</string>
									</property>
								</widget>
							</item>

							<!-- FEATURES -->
							<item>
								<widget class="QLabel" name="sectionTitle">
									<property name="text">
										<string>Features</string>
									</property>
								</widget>
							</item>

							<item>
								<layout class="QHBoxLayout">
									<property name="spacing">
										<number>30</number>
									</property>

									<item>
										<widget class="QFrame" name="card">
											<layout class="QVBoxLayout">
												<item>
													<widget class="QLabel">
														<property name="text">
															<string>Wallet</string>
														</property>
													</widget>
												</item>
												<item>
													<widget class="QLabel" name="mutedText">
														<property name="text">
															<string>Secure balance and transactions</string>
														</property>
													</widget>
												</item>
											</layout>
										</widget>
									</item>

									<item>
										<widget class="QFrame" name="card">
											<layout class="QVBoxLayout">
												<item>
													<widget class="QLabel">
														<property name="text">
															<string>P2P Transfer</string>
														</property>
													</widget>
												</item>
												<item>
													<widget class="QLabel" name="mutedText">
														<property name="text">
															<string>Instant money transfers</string>
														</property>
													</widget>
												</item>
											</layout>
										</widget>
									</item>

									<item>
										<widget class="QFrame" name="card">
											<layout class="QVBoxLayout">
												<item>
													<widget class="QLabel">
														<property name="text">
															<string>Analytics</string>
														</property>
													</widget>
												</item>
												<item>
													<widget class="QLabel" name="mutedText">
														<property name="text">
															<string>Track spending insights</string>
														</property>
													</widget>
												</item>
											</layout>
										</widget>
									</item>

								</layout>
							</item>

							<!-- ABOUT -->
							<item>
								<widget class="QLabel" name="sectionTitle">
									<property name="text">
										<string>About CalxSecure</string>
									</property>
								</widget>
							</item>

							<item>
								<widget class="QLabel" name="mutedText">
									<property name="wordWrap">
										<bool>true</bool>
									</property>
									<property name="text">
										<string>
											CalxSecure is a modern fintech platform focused on ultra-secure, high-speed digital payments.
											We combine encryption, real-time processing, and intuitive UX to redefine financial interactions.
										</string>
									</property>
								</widget>
							</item>

							<!-- CTA -->
							<item alignment="Qt::AlignHCenter">
								<widget class="QFrame" name="card">
									<layout class="QVBoxLayout">
										<item>
											<widget class="QLabel">
												<property name="text">
													<string>Start your secure journey today</string>
												</property>
											</widget>
										</item>
										<item alignment="Qt::AlignHCenter">
											<widget class="QPushButton" name="primaryBtn">
												<property name="text">
													<string>Go to Dashboard</string>
												</property>
											</widget>
										</item>
									</layout>
								</widget>
							</item>

							<!-- FOOTER -->
							<item>
								<widget class="QFrame" name="footer">
									<layout class="QHBoxLayout">
										<item>
											<widget class="QLabel" name="mutedText">
												<property name="text">
													<string>© 2026 CalxSecure</string>
												</property>
											</widget>
										</item>
										<item>
											<spacer name="spacer">
												<property name="orientation">
													<enum>Qt::Horizontal</enum>
												</property>
											</spacer>
										</item>
										<item>
											<widget class="QLabel" name="mutedText">
												<property name="text">
													<string>Privacy • Terms • Security</string>
												</property>
											</widget>
										</item>
									</layout>
								</widget>
							</item>

						</layout>
					</widget>
				</widget>
			</item>

		</layout>
	</widget>
</UI>