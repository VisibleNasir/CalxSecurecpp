<UI version="4.0">
	<class>HomeClass</class>
	<widget class="QWidget" name="HomeClass">
		<property name="styleSheet">
			<string notr="true">
				/* Advanced Inner Styling overrides for Home only */
				QWidget#HomeClass { background-color: transparent; }
				
				QPushButton#btnGetStarted {
					background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #4f46e5, stop:1 #7c3aed);
					color: white;
					font-size: 16px;
					font-weight: bold;
					border: none;
					border-radius: 12px;
					padding: 16px 36px;
				}
				QPushButton#btnGetStarted:hover {
					background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #6366f1, stop:1 #8b5cf6);
				}
				
				QLabel#heroTitle { font-size: 56px; font-weight: 900; color: #ffffff; }
				QLabel#heroSubtitle { font-size: 20px; color: #a1a1aa; }
				QLabel#sectionTitle { font-size: 32px; font-weight: bold; color: #ffffff; margin-top: 40px; }
				
				QFrame#featureCard {
					background-color: #121214;
					border: 1px solid #27272a;
					border-radius: 16px;
					padding: 32px;
				}
				QFrame#featureCard:hover {
					background-color: #18181b;
					border: 1px solid #4f46e5;
				}
				QLabel#cardTitle { font-size: 20px; font-weight: bold; color: #ffffff; margin-bottom: 8px;}
				QLabel#cardDesc { font-size: 15px; color: #a1a1aa; }
			</string>
		</property>
		<layout class="QVBoxLayout">
			<property name="margin"><number>0</number></property>
			<item>
				<widget class="QScrollArea" name="scrollArea">
					<property name="widgetResizable"><bool>true</bool></property>
					<widget class="QWidget" name="scrollContent">
						<layout class="QVBoxLayout">
							<property name="spacing"><number>60</number></property>
							<property name="leftMargin"><number>100</number></property>
							<property name="rightMargin"><number>100</number></property>
							<property name="topMargin"><number>80</number></property>
							<property name="bottomMargin"><number>80</number></property>

							<!-- HERO SECTION -->
							<item alignment="Qt::AlignHCenter">
								<widget class="QLabel" name="heroTitle">
									<property name="text"><string>The Future of Secure Finance</string></property>
								</widget>
							</item>
							<item alignment="Qt::AlignHCenter">
								<widget class="QLabel" name="heroSubtitle">
									<property name="text"><string>Experience ultra-fast, encrypted peer-to-peer transfers worldwide.</string></property>
								</widget>
							</item>
							<item alignment="Qt::AlignHCenter">
								<widget class="QPushButton" name="btnGetStarted">
									<property name="text"><string>Launch Dashboard</string></property>
									<property name="cursor"><cursorShape>PointingHandCursor</cursorShape></property>
								</widget>
							</item>

							<!-- FEATURES SECTION -->
							<item alignment="Qt::AlignHCenter">
								<widget class="QLabel" name="sectionTitle">
									<property name="text"><string>Why Choose CalxSecure?</string></property>
								</widget>
							</item>
							<item>
								<layout class="QHBoxLayout">
									<property name="spacing"><number>40</number></property>
									<item>
										<widget class="QFrame" name="featureCard">
											<layout class="QVBoxLayout">
												<item><widget class="QLabel" name="cardTitle"><property name="text"><string>Zero-Knowledge Safety</string></property></widget></item>
												<item><widget class="QLabel" name="cardDesc"><property name="text"><string>AES-256 bit encryption ensures nobody sees your transactions except you.</string></property><property name="wordWrap"><bool>true</bool></property></widget></item>
											</layout>
										</widget>
									</item>
									<item>
										<widget class="QFrame" name="featureCard">
											<layout class="QVBoxLayout">
												<item><widget class="QLabel" name="cardTitle"><property name="text"><string>Instant P2P</string></property></widget></item>
												<item><widget class="QLabel" name="cardDesc"><property name="text"><string>Send and request money in under 2 seconds across the entire network.</string></property><property name="wordWrap"><bool>true</bool></property></widget></item>
											</layout>
										</widget>
									</item>
									<item>
										<widget class="QFrame" name="featureCard">
											<layout class="QVBoxLayout">
												<item><widget class="QLabel" name="cardTitle"><property name="text"><string>Smart Fraud AI</string></property></widget></item>
												<item><widget class="QLabel" name="cardDesc"><property name="text"><string>Machine learning constantly maps behavior to halt suspicious anomalies instantly.</string></property><property name="wordWrap"><bool>true</bool></property></widget></item>
											</layout>
										</widget>
									</item>
								</layout>
							</item>
						</layout>
					</widget>
				</widget>
			</item>
		</layout>
	</widget>
</UI>