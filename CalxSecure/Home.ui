		<property name="styleSheet">
			<string notr="true">
				QWidget#HomeClass {
				background-color: #0f0f12;
				}
				QFrame#topDock {
				background-color: #1a1a1f;
				border-bottom: 1px solid #333333;
				}
				QPushButton {
				font-size: 15px;
				font-weight: 600;
				padding: 12px 28px;
				border: none;
				border-radius: 10px;
				color: #e0e0e0;
				background-color: transparent;
				}
				QPushButton:hover {
				background-color: #ffffff;
				color: #000000;
				}
				QPushButton:pressed {
				background-color: #cccccc;
				}
				QLabel#title {
				font-size: 48px;
				font-weight: 800;
				color: #ffffff;
				}
				QLabel#subtitle {
				font-size: 20px;
				color: #aaaaaa;
				}
				QFrame#securityCard {
				background-color: #1a1a1f;
				border: 1px solid #333333;
				border-radius: 16px;
				padding: 32px;
				}
				QLabel#cardTitle {
				font-size: 20px;
				font-weight: 700;
				color: #ffffff;
				}
				QLabel#cardDesc {
				color: #aaaaaa;
				}
			</string>
