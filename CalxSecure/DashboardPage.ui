<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
	<class>DashboardPageClass</class>
	<widget class="QWidget" name="DashboardPageClass">
		<property name="geometry">
			<rect>
				<x>0</x>
				<y>0</y>
				<width>1280</width>
				<height>820</height>
			</rect>
		</property>
		<property name="styleSheet">
			<string notr="true">
				QWidget#DashboardPageClass {
				background-color: #09090b;
				font-family: Inter, Segoe UI, sans-serif;
				color: #ffffff;
				}

				/* Sidebar */
				QWidget#Sidebar {
				background-color: #0a0a0a;
				border-right: 1px solid #27272a;
				min-width: 260px;
				}

				QPushButton {
				text-align: left;
				padding: 14px 24px;
				border: none;
				background: transparent;
				color: #e5e5e5;
				font-size: 15px;
				font-weight: 500;
				}

				QPushButton:hover {
				background-color: #1f1f22;
				color: #ffffff;
				}

				QPushButton:checked {
				background-color: #18181b;
				color: #60a5fa;
				border-left: 4px solid #60a5fa;
				}

				/* Cards */
				QFrame#card, QFrame#statsCard, QFrame#balanceCard, QFrame#card_2, QFrame#card_3 {
				background-color: #111113;
				border: 1px solid #27272a;
				border-radius: 20px;
				padding: 24px;
				}

				/* Typography */
				QLabel {
				color: #ffffff;
				}

				QLabel#greeting {
				font-size: 28px;
				font-weight: 600;
				}

				QLabel#balanceAmount {
				font-size: 48px;
				font-weight: 700;
				letter-spacing: -1px;
				}

				QLabel[class="subheading"] {
				font-size: 18px;
				font-weight: 500;
				color: #a1a1aa;
				}

				/* Buttons */
				QPushButton {
				border-radius: 12px;
				padding: 12px 20px;
				font-weight: 600;
				}

				QPushButton#btnShowBalance {
				background-color: #18181b;
				border: 1px solid #3b82f6;
				color: #ffffff;
				}

				QPushButton#btnSendMoney, QPushButton#btnAddFunds, QPushButton#btnAddFundsConfirm,
				QPushButton#btnPay, QPushButton#btnRecharge {
				background-color: #3b82f6;
				color: #ffffff;
				}

				QPushButton:hover {
				background-color: #2563eb;
				}

				/* Form Elements */
				QLineEdit, QDoubleSpinBox, QComboBox {
				background-color: #1f1f23;
				border: 1px solid #3b82f6;
				border-radius: 10px;
				padding: 10px;
				color: #ffffff;
				}

				QListWidget {
				background-color: transparent;
				border: none;
				}

				QListWidget::item {
				padding: 12px;
				border-bottom: 1px solid #1f1f23;
				color: #e5e5e5;
				}
			</string>
		</property>

